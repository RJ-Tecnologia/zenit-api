{
  "name": "zenit-finance-api",
  "version": "1.0.0",
  "description": "API REST do projeto Zenit Finance",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "prebuild": "prisma migrate deploy && prisma generate",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "lint": "biome check",
    "format": "biome format --write .",
    "check-types": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@scalar/fastify-api-reference": "^1.48.5",
    "better-auth": "^1.5.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  }
}
